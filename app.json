{
  "expo": {
    "name": "Seekr",
    "slug": "seekr",
    "scheme": "seekr",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "platforms": [
      "ios"
    ],
    "ios": {
      "bundleIdentifier": "com.seekr.app",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0f1a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3a6c6ae7-15f0-43ee-b3db-6e16c35b3149"
      }
    },
    "owner": "hashdev72"
  }
}

{
  "expo": {
    "name": "Seekr",
    "slug": "seekr",
    "scheme": "seekr",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "platforms": [
      "ios"
    ],
    "ios": {
      "bundleIdentifier": "com.seekr.app",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0f1a"
        }
      ],
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
